int buttonState = 0;
const int LED =3;
void setup()
{
  pinMode(2,INPUT);
  pinMode(LED, OUTPUT);
  Serial.begin(9600);
}

void loop()
{
  buttonState = digitalRead(2);
  Serial.println(buttonState);
  if (buttonState ==1) {
  digitalWrite(LED, HIGH);
  delay(500);
  }
  else {
  digitalWrite(LED, LOW);
  }
  delay(10);
}
